     "edge-tts>=7.0.0",
-    "sounddevice>=0.4.0",
     "openai>=1.0.0",
     "python-dotenv>=1.0.0",
     "pyautogui>=0.9.54",
@@ -27,7 +25,20 @@ dependencies = [
 ]
 
 [project.optional-dependencies]
-windows = ["pywinauto>=0.6.9"]
+voice = [
+    "RealtimeSTT>=1.0.0",
+    "sounddevice>=0.4.0",
